generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum Role {
  OWNER
  MEMBER
}

enum ProjectStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  NONE
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum IssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum JoinStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum EmailUrgency {
  URGENT
  NEEDS_RESPONSE
  FYI
  LOW
}

enum EmailCategory {
  MEETING
  QUESTION
  NEWSLETTER
  TRANSACTIONAL
  PROMOTION
  NOTIFICATION
  PERSONAL
  OTHER
}

model User {
  id         String       @id @default(cuid())
  email      String       @unique
  name       String
  username   String?      @unique
  password   String?
  avatarUrl  String?
  provider   AuthProvider @default(EMAIL)
  googleId   String?      @unique
  lastSeenAt DateTime?

  memberships          Membership[]
  teamMemberships      TeamMembership[]
  joinRequests         TeamJoinRequest[]
  sentInvites          TeamInvite[]      @relation("InviteInviter")
  notifications        Notification[]
  ledProjects          Project[]         @relation("ProjectLead")
  projectMembers       ProjectMember[]
  assignedIssues       Issue[]           @relation("IssueAssignee")
  createdIssues        Issue[]           @relation("IssueCreator")
  comments             Comment[]
  sessions             UserSession[]
  apiKeys              ApiKey[]
  gitPersonaCard       GitPersonaCard?
  gitPersonaGeneration GitPersonaGeneration?
  gmailConnection      GmailConnection?
  inboxEmails          InboxEmail[]
  inboxRun             InboxRun?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  hint       String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model UserSession {
  id           String    @id @default(cuid())
  sessionId    String    @unique @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  userAgent    String?
  ipAddress    String?
  location     String?
  expiresAt    DateTime?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Workspace {
  id      String  @id @default(cuid())
  name    String
  logoUrl String?

  memberships Membership[]
  teams       Team[]
  labels      Label[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id   String @id @default(cuid())
  role Role   @default(MEMBER)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  createdAt DateTime @default(now())

  @@unique([userId, workspaceId])
}

model Team {
  id          String  @id @default(cuid())
  name        String
  key         String
  icon        String?
  color       String?
  description String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  memberships  TeamMembership[]
  joinRequests TeamJoinRequest[]
  invites      TeamInvite[]
  github       GithubConnection?
  slack        SlackConnection?
  notion       NotionConnection?
  projects     Project[]
  issues       Issue[]
  issueCounter Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, key])
}

model TeamMembership {
  id   String   @id @default(cuid())
  role TeamRole @default(MEMBER)

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
}

model TeamJoinRequest {
  id     String     @id @default(cuid())
  status JoinStatus @default(PENDING)

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
}

model TeamInvite {
  id        String       @id @default(cuid())
  email     String
  token     String       @unique
  role      TeamRole     @default(MEMBER)
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  acceptedAt DateTime?

  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      String
  invitedBy   User?   @relation("InviteInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedById String?

  createdAt DateTime @default(now())

  @@index([teamId])
  @@index([email])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  summary     String?
  description String?
  icon        String?
  color       String?
  status      ProjectStatus @default(BACKLOG)
  priority    Priority      @default(NONE)
  sortOrder   Int           @default(0)
  repoFullName String?
  startDate   DateTime?
  targetDate  DateTime?

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  lead   User?  @relation("ProjectLead", fields: [leadId], references: [id])
  leadId String?

  members    ProjectMember[]
  labels     Label[]         @relation("ProjectLabels")
  milestones Milestone[]
  issues     Issue[]

  dependsOn  Project[] @relation("ProjectDeps")
  dependents Project[] @relation("ProjectDeps")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
}

model ProjectMember {
  id        String @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Label {
  id    String @id @default(cuid())
  name  String
  color String @default("#5e6ad2")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  projects Project[] @relation("ProjectLabels")
  issues   Issue[]   @relation("IssueLabels")

  createdAt DateTime @default(now())

  @@unique([workspaceId, name])
}

model Milestone {
  id         String    @id @default(cuid())
  name       String
  targetDate DateTime?
  sortOrder  Int       @default(0)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  createdAt DateTime @default(now())

  @@index([projectId])
}

model Issue {
  id          String      @id @default(cuid())
  number      Int
  title       String
  description String?
  status      IssueStatus @default(TODO)
  priority    Priority    @default(NONE)
  sortOrder   Int         @default(0)
  images      String[]    @default([])

  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId     String
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId  String?
  assignee   User?    @relation("IssueAssignee", fields: [assigneeId], references: [id])
  assigneeId String?
  createdBy   User?   @relation("IssueCreator", fields: [createdById], references: [id])
  createdById String?

  parent   Issue?  @relation("IssueChildren", fields: [parentId], references: [id], onDelete: SetNull)
  parentId String?
  children Issue[] @relation("IssueChildren")

  labels       Label[]           @relation("IssueLabels")
  comments     Comment[]
  pullRequests PullRequestLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, number])
  @@index([projectId])
  @@index([parentId])
}

model Comment {
  id   String @id @default(cuid())
  body String

  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId  String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([issueId])
}

model Notification {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  type  String
  title String
  body  String?
  link  String?

  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model GithubConnection {
  id             String  @id @default(cuid())
  team           Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         String  @unique
  installationId String?
  account        String?
  accountType    String?
  repoFullName   String?
  active         Boolean @default(true)

  createdAt DateTime @default(now())
}

model SlackConnection {
  id            String  @id @default(cuid())
  team          Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId        String  @unique
  webhookUrl    String
  channel       String?
  channelId     String?
  slackTeamId   String?
  slackTeamName String?
  accessToken   String?
  active        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotionConnection {
  id            String  @id @default(cuid())
  team          Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId        String  @unique
  accessToken   String
  workspaceId   String
  workspaceName String?
  workspaceIcon String?
  botId         String?
  active        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GitPersonaCard {
  id          String  @id @default(cuid())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String  @unique
  githubLogin String
  avatarUrl   String?
  name        String?
  public      Boolean @default(true)

  styleSummary String
  strengths    Json
  growthArc    String
  roadmap      Json
  stats        Json

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([githubLogin])
}

model GitPersonaGeneration {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  status    String
  error     String?
  startedAt DateTime @default(now())
}

model GmailConnection {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String    @unique
  googleEmail  String
  refreshToken String
  active       Boolean   @default(true)
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InboxEmail {
  id       String @id @default(cuid())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  gmailId  String
  threadId String

  fromName   String?
  fromEmail  String
  subject    String
  snippet    String?
  body       String?
  receivedAt DateTime
  isBulk     Boolean  @default(false)

  urgency  EmailUrgency?
  category EmailCategory?
  reason   String?
  score    Float          @default(0)
  topRank  Int?

  draftId        String?
  draftMessageId String?
  draftBody      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gmailId])
  @@index([userId, topRank])
  @@index([userId, urgency])
}

model InboxRun {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String    @unique
  status        String
  step          String?
  error         String?
  totalFetched  Int       @default(0)
  classified    Int       @default(0)
  draftsCreated Int       @default(0)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
}

model PullRequestLink {
  id      String @id @default(cuid())
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String

  number Int?
  title  String?
  url    String
  state  String  @default("open")
  author String?

  createdAt DateTime @default(now())

  @@unique([issueId, url])
  @@index([issueId])
}
