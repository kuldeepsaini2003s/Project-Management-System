generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum Role {
  OWNER
  MEMBER
}

enum ProjectStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  NONE
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum IssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum JoinStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model User {
  id         String       @id @default(cuid())
  email      String       @unique
  name       String
  username   String?      @unique
  password   String?
  avatarUrl  String?
  provider   AuthProvider @default(EMAIL)
  googleId   String?      @unique
  lastSeenAt DateTime?

  memberships     Membership[]
  teamMemberships TeamMembership[]
  joinRequests    TeamJoinRequest[]
  sentInvites     TeamInvite[]      @relation("InviteInviter")
  notifications   Notification[]
  ledProjects     Project[]         @relation("ProjectLead")
  projectMembers  ProjectMember[]
  assignedIssues  Issue[]           @relation("IssueAssignee")
  createdIssues   Issue[]           @relation("IssueCreator")
  comments        Comment[]
  sessions        UserSession[]
  apiKeys         ApiKey[]
  gitPersonaCard  GitPersonaCard?
  gitPersonaGeneration GitPersonaGeneration?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique  // full token — shown once on creation
  hint       String             // last 6 chars for display (e.g. "…Xk2a9f")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model UserSession {
  id           String    @id @default(cuid())
  sessionId    String    @unique @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  userAgent    String?
  ipAddress    String?
  location     String?
  // Nullable and only ever set going forward (see UserService.createSession) —
  // this is what lets the Security page show only genuinely active sessions:
  // pre-existing rows have expiresAt = null and are simply filtered out,
  // rather than needing a manual data migration to purge old ghost entries.
  expiresAt    DateTime?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Workspace {
  id      String  @id @default(cuid())
  name    String
  logoUrl String?

  memberships Membership[]
  teams       Team[]
  labels      Label[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id   String @id @default(cuid())
  role Role   @default(MEMBER)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  createdAt DateTime @default(now())

  @@unique([userId, workspaceId])
}

model Team {
  id          String  @id @default(cuid())
  name        String
  key         String // short prefix, e.g. ALG
  icon        String?
  color       String?
  description String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  memberships  TeamMembership[]
  joinRequests TeamJoinRequest[]
  invites      TeamInvite[]
  github       GithubConnection?
  slack        SlackConnection?
  notion       NotionConnection?
  projects     Project[]
  issues       Issue[]
  issueCounter Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, key])
}

model TeamMembership {
  id   String   @id @default(cuid())
  role TeamRole @default(MEMBER)

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
}

model TeamJoinRequest {
  id     String     @id @default(cuid())
  status JoinStatus @default(PENDING)

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
}

model TeamInvite {
  id        String       @id @default(cuid())
  email     String
  token     String       @unique
  role      TeamRole     @default(MEMBER)
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  acceptedAt DateTime?

  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      String
  invitedBy   User?   @relation("InviteInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedById String?

  createdAt DateTime @default(now())

  @@index([teamId])
  @@index([email])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  summary     String?
  description String?
  icon        String?
  color       String?
  status      ProjectStatus @default(BACKLOG)
  priority    Priority      @default(NONE)
  sortOrder   Int           @default(0)
  repoFullName String?      // linked GitHub repository (owner/name)
  startDate   DateTime?
  targetDate  DateTime?

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  lead   User?  @relation("ProjectLead", fields: [leadId], references: [id])
  leadId String?

  members    ProjectMember[]
  labels     Label[]         @relation("ProjectLabels")
  milestones Milestone[]
  issues     Issue[]

  dependsOn  Project[] @relation("ProjectDeps")
  dependents Project[] @relation("ProjectDeps")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
}

model ProjectMember {
  id        String @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Label {
  id    String @id @default(cuid())
  name  String
  color String @default("#5e6ad2")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  projects Project[] @relation("ProjectLabels")
  issues   Issue[]   @relation("IssueLabels")

  createdAt DateTime @default(now())

  @@unique([workspaceId, name])
}

model Milestone {
  id         String    @id @default(cuid())
  name       String
  targetDate DateTime?
  sortOrder  Int       @default(0)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  createdAt DateTime @default(now())

  @@index([projectId])
}

model Issue {
  id          String      @id @default(cuid())
  number      Int
  title       String
  description String?
  status      IssueStatus @default(TODO)
  priority    Priority    @default(NONE)
  sortOrder   Int         @default(0)
  images      String[]    @default([])

  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId     String
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId  String?
  assignee   User?    @relation("IssueAssignee", fields: [assigneeId], references: [id])
  assigneeId String?
  createdBy   User?   @relation("IssueCreator", fields: [createdById], references: [id])
  createdById String?

  parent   Issue?  @relation("IssueChildren", fields: [parentId], references: [id], onDelete: SetNull)
  parentId String?
  children Issue[] @relation("IssueChildren")

  labels       Label[]           @relation("IssueLabels")
  comments     Comment[]
  pullRequests PullRequestLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, number])
  @@index([projectId])
  @@index([parentId])
}

model Comment {
  id   String @id @default(cuid())
  body String

  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId  String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([issueId])
}

model Notification {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  type  String // ISSUE_ASSIGNED, ISSUE_COMMENT, JOIN_REQUEST, JOIN_ACCEPTED, ...
  title String
  body  String?
  link  String? // in-app route to open

  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model GithubConnection {
  id             String  @id @default(cuid())
  team           Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         String  @unique
  installationId String? // GitHub App installation id
  account        String? // login of the org/user the app was installed on
  accountType    String? // "User" or "Organization"
  repoFullName   String? // optional default repo (repos are linked per project)
  active         Boolean @default(true) // false = disconnected in-app (record kept to allow reconnect)

  createdAt DateTime @default(now())
}

model SlackConnection {
  id            String  @id @default(cuid())
  team          Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId        String  @unique
  webhookUrl    String
  channel       String? // e.g. "#general"
  channelId     String? // e.g. "C123ABC" — Slack channel ID for API calls
  slackTeamId   String? // Slack workspace ID (T...)
  slackTeamName String? // Slack workspace display name
  accessToken   String? // Slack bot token (xoxb-...) for API calls
  active        Boolean @default(true) // false = disconnected in-app (record kept to allow reconnect)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotionConnection {
  id            String  @id @default(cuid())
  team          Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId        String  @unique
  accessToken   String  // Notion bot access token
  workspaceId   String  // Notion workspace ID
  workspaceName String? // Notion workspace display name
  workspaceIcon String? // Notion workspace icon URL
  botId         String? // Notion bot ID
  active        Boolean @default(true) // false = disconnected in-app (record kept to allow reconnect)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// The generated GitPersona developer identity card — cached so it isn't
// regenerated on every view, regenerated on demand via "Regenerate". There is
// deliberately no separate "connection" table here: GitPersona reuses the
// existing team-level GithubConnection (installed from Settings → Connected
// accounts) for both auth and repo data, so connecting GitHub from either
// page reflects on both — one table, one source of truth.
model GitPersonaCard {
  id          String  @id @default(cuid())
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String  @unique
  githubLogin String // the GitHub account the card was generated for (denormalized for public lookup)
  avatarUrl   String?
  name        String?
  public      Boolean @default(true) // whether /dev/:login can be viewed by anyone

  styleSummary String
  strengths    Json // [{ title, evidence }]
  growthArc    String
  roadmap      Json // [{ title, why, resourceHint }]
  stats        Json // { topLanguages, totalRepos, totalCommits, ... } raw evidence backing the analysis

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([githubLogin])
}

// Tracks an in-flight (or last-failed) card generation, separate from
// GitPersonaCard itself. Generation is kicked off in the background and
// survives the client disconnecting/navigating away (see
// GitPersonaService.startGenerateCard) — this row is what lets the frontend
// resume showing "generating…" if the user comes back mid-run, and is also
// what makes clicking Generate twice a no-op instead of starting a second,
// wasteful, racing AI/GitHub pipeline for the same user.
model GitPersonaGeneration {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  status    String // "pending" | "failed" — row is deleted entirely on success
  error     String? // set when status = "failed"
  startedAt DateTime @default(now())
}

model PullRequestLink {
  id      String @id @default(cuid())
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String

  number Int?
  title  String?
  url    String
  state  String  @default("open") // open, closed, merged
  author String?

  createdAt DateTime @default(now())

  @@unique([issueId, url])
  @@index([issueId])
}
